# Ignore Terraform state files and local state
# These contain sensitive info and should NOT be committed to Git
*.tfstate
*.tfstate.*

# Terraform working directory (created by terraform init)
.terraform/

# Lock file (can be committed but sometimes causes issues)
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (may contain passwords)
# Uncomment the line below if your tfvars has real secrets
# *.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
